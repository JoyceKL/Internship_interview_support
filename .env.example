APP_NAME=Internship Interview Support V2
ENV=dev
SECRET_KEY=change-me-in-local
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080
ALGORITHM=HS256

# Docker compose runtime DB URL (api container -> db service)
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/interview_support

# OpenAI (Responses API + Structured Outputs)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_MAX_RETRIES=2

CORS_ORIGINS=["*"]

DATA_DIR=data
CV_UPLOAD_DIR=data/uploads/cv
JD_UPLOAD_DIR=data/uploads/jd
EXPORTS_DIR=data/exports
